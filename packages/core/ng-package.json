{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/kj-core",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    {
      "input": "src/typography",
      "glob": "prose.css",
      "output": "typography"
    },
    {
      "input": "src/icon",
      "glob": "icon.css",
      "output": "icon"
    },
    {
      "input": "src/motion",
      "glob": "motion.css",
      "output": "motion"
    }
  ],
  "allowedNonPeerDependencies": [
    "@tanstack/angular-table"
  ]
}
