{
  "name": "@kouji-ui/core",
  "version": "1.0.0",
  "description": "Headless Angular 21 UI primitives — directives over CDK with WCAG 2.1 AAA semantics and zero CSS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kouji-dev/kouji-ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://kouji-ui.onrender.com",
  "bugs": {
    "url": "https://github.com/kouji-dev/kouji-ui/issues"
  },
  "keywords": [
    "angular",
    "ui",
    "headless",
    "directives",
    "cdk",
    "a11y",
    "wcag"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "module": "fesm2022/kouji-ui-core.mjs",
    "typings": "types/kouji-ui-core.d.ts",
    "exports": {
      "./package.json": {
        "default": "./package.json"
      },
      ".": {
        "types": "./types/kouji-ui-core.d.ts",
        "default": "./fesm2022/kouji-ui-core.mjs"
      }
    }
  },
  "peerDependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/cdk": "^22.0.0"
  },
  "sideEffects": false,
  "type": "module",
  "module": "../../dist/kj-core/fesm2022/kouji-ui-core.mjs",
  "typings": "../../dist/kj-core/types/kouji-ui-core.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "../../dist/kj-core/types/kouji-ui-core.d.ts",
      "default": "../../dist/kj-core/fesm2022/kouji-ui-core.mjs"
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.prod.json",
    "test": "vitest run",
    "lint": "ng lint kj-core"
  }
}
