{
  "name": "kouji",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test --coverage",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "a11y": "pnpm --filter @kouji-ui/a11y start",
    "build:core": "turbo run build --filter=@kouji-ui/core",
    "build:docs": "turbo run build --filter=docs",
    "format": "prettier --write \"**/*.{ts,html,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,css,json,md}\"",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@angular/cdk": "~22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-server": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@angular/ssr": "^22.0.5",
    "@lexical/code": "^0.38.0",
    "@lexical/history": "^0.38.0",
    "@lexical/html": "^0.38.0",
    "@lexical/link": "^0.38.0",
    "@lexical/list": "^0.38.0",
    "@lexical/markdown": "^0.38.0",
    "@lexical/rich-text": "^0.38.0",
    "@lexical/selection": "^0.38.0",
    "@monaco-editor/loader": "^1.7.0",
    "@phenomnomnominal/tsquery": "^6.2.0",
    "@stackblitz/sdk": "^1.11.0",
    "@tanstack/angular-table": "^8.21.4",
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/virtual-core": "^3.14.0",
    "codemirror": "^6.0.2",
    "culori": "^4.0.2",
    "echarts": "^6.0.0",
    "express": "^5.1.0",
    "lexical": "^0.38.0",
    "lucide-static": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "rxjs": "~7.8.0",
    "ts-morph": "^28.0.0",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.3-beta.2",
    "@analogjs/vitest-angular": "2.6.3-beta.2",
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/echarts": "^5.0.0",
    "@types/express": "^5.0.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "ng-packagr": "^22.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.5",
    "zone.js": "^0.16.1"
  }
}
