{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:docs",
  "outputDirectory": "dist/docs/browser",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/docs/server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
