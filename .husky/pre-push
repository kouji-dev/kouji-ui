#!/usr/bin/env sh

# Skip in CI — automated pushes (Changesets action, dependabot, etc.) shouldn't
# re-run local quality gates the workflow already enforces.
if [ -n "$CI" ] || [ -n "$GITHUB_ACTIONS" ]; then
  echo "→ skipping pre-push (CI environment detected)"
  exit 0
fi

set -e

echo "→ lint"
pnpm lint

echo "→ test"
pnpm test

echo "→ build"
pnpm build

echo "→ changeset status (publishable changes need a changeset)"
pnpm exec changeset status --since=origin/main || {
  echo ""
  echo "  No changeset found for publishable changes."
  echo "  Run: pnpm changeset"
  echo "  (or: skip if your change touches only apps/docs, .github/, rules/, or root config)"
  exit 1
}
